script = ExtResource("1")
effect_id = &"ignite"
display_name = "Ignite"
description = "Burning. Deals fire damage per second for several seconds. Damage applies to energy shield first, then life. Cannot be inflicted again by a weaker ignite while a stronger one is active.

Scales with the attacker's Ignite Effect %, Ignite Duration %, and the generic Damage over Time % stat. Duration scales independently of damage — a longer ignite is a longer-lasting burn at the same DPS, dealing more total damage."
duration_seconds = 4.0
refresh_mode = 3
is_damage_over_time = true
per_tick_effects = {
"fire_damage_per_sec": 100.0
}
