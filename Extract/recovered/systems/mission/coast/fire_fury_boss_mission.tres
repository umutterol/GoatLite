[resource]
script = ExtResource("9")
mission_id = "fire_fury_boss_mission"
display_name = "Through Fire and Flames"
description = "We've found the way forward. It's guarded by the head chef of the cannibal tribes. A spicy lass known the Fire Fury. And word is she's pissed off about our raiding of her camps. Hungry, angry, and a downright cannibal army at her command. But we can't just stay here and slowly get eaten while we starve."
icon = null
level = 6
mission_tags = [5]
prerequisites = [SubResource("Resource_ehhc0")]
scouting_threshold_percent = 100.0
boss_mission = true
boss_cooldown_days = 7
mission_length = 2
encounter_slots = [SubResource("Resource_qwegp"), SubResource("Resource_gyx8c")]
scouting_reward = 10.0
rarity_bonus = 0.2
quantity_bonus = 0.2
mission_rewards = null
