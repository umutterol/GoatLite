stat_id = "poison_duration_reduction_pct"
display_name = "Reduced Poison Duration"
description = "% reduction to the duration of incoming Poison stacks. Stacks additively, clamped 0-100. At 100% poisons expire immediately. NOTE: Chaos Resistance handles per-hit damage reduction (it scales the source chaos damage that feeds the poison DPS calc); this stat is the orthogonal duration lever."
category = 1
stat_type = 1
min_value = 0.0
max_value = 100.0
show_as_percentage = true
