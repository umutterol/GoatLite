display_name = "Poison Effect"
description = "% bonus to the per-second DAMAGE of Poison stacks you apply. Does NOT change duration — extends time only via Poison Duration. Composes additively with Damage over Time. Final DPS per stack = base × (1 + effect%/100) × (1 + DoT%/100)."
